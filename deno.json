{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno serve --allow-env --allow-net --allow-read --watch server.tsx"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "@hono/hono/jsx",
    "lib": [
      "deno.ns",
      "dom"
    ]
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.7.10",
    "@neon/serverless": "jsr:@neon/serverless@^1.0.1",
    "imagekit": "npm:imagekit@^6.0.0"
  }
}
