{
  "nodeModulesDir": "auto",
  "tasks": {
    "push": "deno run --allow-env --allow-read --allow-net ./scripts/db.ts",
    "dev": "deno serve --allow-env --allow-read --watch server.tsx",
    "tailwind": "tailwindcss -i ./src/input.css -o ./src/tailwind.css"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "@hono/hono/jsx",
    "lib": [
      "deno.ns",
      "deno.unstable",
      "dom"
    ]
  },
  "unstable": ["kv"],
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.7.10",
    "@neon/serverless": "jsr:@neon/serverless@^1.0.1",
    "@std/assert": "jsr:@std/assert@^1.0.13",
    "@tailwindcss/cli": "npm:@tailwindcss/cli@^4.1.8",
    "drizzle-kit": "npm:drizzle-kit@^0.31.1",
    "drizzle-orm": "npm:drizzle-orm@^0.44.2",
    "imagekit": "npm:imagekit@^6.0.0",
    "tailwindcss": "npm:tailwindcss@^4.1.8"
  }
}
