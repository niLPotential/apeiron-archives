{
  "tasks": {
    "push": "deno run --allow-env --allow-read --allow-net ./scripts/db.ts",
    "dev": "deno serve --watch server.tsx"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "@hono/hono/jsx",
    "lib": [
      "deno.ns",
      "deno.unstable",
      "dom"
    ]
  },
  "unstable": ["kv"],
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.7.10",
    "@neon/serverless": "jsr:@neon/serverless@^1.0.1",
    "@std/assert": "jsr:@std/assert@^1.0.13"
  }
}
